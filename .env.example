# ─── LLM Provider ────────────────────────────────────────────────────────────
# Default is OpenAI. Leave LLM_PROVIDER unset (or =openai) for the standard setup.
LLM_PROVIDER=openai

# ── OpenAI (default provider) ──
OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o            # optional override

# ── Amazon Bedrock (optional — only used when LLM_PROVIDER=bedrock) ──
# Requires:  pip install langchain-aws
# Uses standard AWS credentials (AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY or an IAM role)
# AWS_REGION=us-east-1
# BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0
